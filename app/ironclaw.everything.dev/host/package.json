    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "dotenv": "^17.2.3",
    "every-plugin": "catalog:",
    "pg": "catalog:",
    "@electric-sql/pglite": "catalog:",
    "hono": "^4.12.18",
    "react": "catalog:",
    "react-dom": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "everything-dev": "catalog:",
    "@module-federation/rsbuild-plugin": "catalog:",
    "@rsbuild/core": "catalog:",
    "@rsbuild/plugin-react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "every-plugin": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
