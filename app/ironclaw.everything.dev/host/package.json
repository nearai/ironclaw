{
  "name": "host",
  "version": "1.11.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "BOS_CONFIG_PATH=../bos.config.json tsx server.ts",
    "build": "rsbuild build",
    "deploy": "DEPLOY=true rsbuild build",
    "preview": "NODE_ENV=production BOS_CONFIG_PATH=../bos.config.json tsx server.ts",
    "test": "NODE_ENV=production BOS_CONFIG_PATH=../bos.config.json vitest run",
    "test:e2e": "BOS_CONFIG_PATH=../bos.config.json playwright test -c ./playwright.config.mjs",
    "test:integration:remote": "BOS_CONFIG_PATH=../bos.config.json vitest run -c ./vitest.remote.config.ts",
    "test:watch": "NODE_ENV=production BOS_CONFIG_PATH=../bos.config.json vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
