{
  "extends": "bos://work.efiz.near/nearbuilders.org",
  "account": "work.efiz.near",
  "domain": "ironclaw.nearbuilders.org",
  "title": "IronClaw",
  "description": "IronClaw Reborn Dashboard Interface",
  "staging": {
    "domain": "dev.everything.dev"
  },
  "repository": "https://github.com/nearai/ironclaw",
  "ci": {
    "railway": {
      "service": "app"
    }
  },
  "app": {
    "host": {
      "development": "local:host",
      "secrets": [
        "CORS_ORIGIN",
        "TENANT_WHITELIST",
        "ALLOW_OVERRIDE",
        "ALLOW_UNTRUSTED_SSR",
        "CSP_STRICT"
      ]
    },
    "ui": {
      "development": "local:ui"
    },
    "api": {
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL"
      ]
    }
  },
  "plugins": {
    "settings": {
      "extends": "bos://work.efiz.near/nearbuilders.org"
    },
    "ironclaw": {
      "development": "local:plugins/ironclaw"
    }
  }
}
