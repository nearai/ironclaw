# Google browser-consent flow
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Preferred: pre-authenticated Playwright storage state for the Google test account.
AUTH_BROWSER_GOOGLE_STORAGE_STATE_PATH=
# Optional fallback if you really want Playwright to type credentials.
AUTH_BROWSER_GOOGLE_USERNAME=
AUTH_BROWSER_GOOGLE_PASSWORD=

# GitHub browser-consent flow
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Preferred: pre-authenticated Playwright storage state for the GitHub test account.
AUTH_BROWSER_GITHUB_STORAGE_STATE_PATH=
# Required so the canary can exercise a real GitHub API call after auth.
AUTH_BROWSER_GITHUB_OWNER=
AUTH_BROWSER_GITHUB_REPO=
AUTH_BROWSER_GITHUB_ISSUE_NUMBER=
# Optional fallback if you really want Playwright to type credentials.
AUTH_BROWSER_GITHUB_USERNAME=
AUTH_BROWSER_GITHUB_PASSWORD=

# Notion browser-consent flow
# Preferred: pre-authenticated Playwright storage state for the Notion test account.
AUTH_BROWSER_NOTION_STORAGE_STATE_PATH=
# Optional fallback if Playwright can use direct credentials in your Notion setup.
AUTH_BROWSER_NOTION_USERNAME=
AUTH_BROWSER_NOTION_PASSWORD=
