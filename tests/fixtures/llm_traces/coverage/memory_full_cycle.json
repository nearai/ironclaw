              "content": "# Coverage Test Note\n\nThis document was created by the memory full cycle test.\n\nKey fact: The answer is 42."
            }
          }
        ],
        "input_tokens": 80,
        "output_tokens": 30
      }
    },
    {
      "response": {
        "type": "tool_calls",
        "tool_calls": [
          {
