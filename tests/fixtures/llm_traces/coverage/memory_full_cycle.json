        ],
        "input_tokens": 150,
        "output_tokens": 15
      }
    },
    {
      "response": {
        "type": "tool_calls",
        "tool_calls": [
          {
            "id": "call_mem_search",
            "name": "memory_search",
            "arguments": {
              "query": "answer is 42"
            }
          }
        ],
        "input_tokens": 180,
        "output_tokens": 15
      }
    },
    {
      "response": {
        "type": "text",
        "content": "I wrote a note to memory, listed the tree, read it back, and searched for it. All four memory operations completed successfully.",
        "input_tokens": 220,
        "output_tokens": 30
      }
    }
  ]
}
