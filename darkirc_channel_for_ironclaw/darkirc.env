# darkirc-bridge environment configuration
# Copy to .env and adjust as needed

# Example variables

# Actual secrets don't even get saved here. This is purely configuration stuff. The only "secret" is the private key which is stored in the DarkIRC daemon configuration which is completely seperate from the tool.
# Therefore, the secret is out of scope of this project

# DarkIRC daemon connection
DARKIRC_HOST=127.0.0.1
DARKIRC_PORT=6667

# Bridge identity on IRC
BRIDGE_NICK=kageho
BRIDGE_USER=kageho

# Unix socket path (shared volume between bridge + ironclaw containers)
BRIDGE_SOCKET=/run/bridge/ironclaw.sock

# Allowlisted nick patterns (comma-separated regexes)
# Empty = allow all (NOT recommended for production)
# Examples:
#   BRIDGE_ALLOWED_NICKS=sun,kageho.*
#   BRIDGE_ALLOWED_NICKS=trusted-[0-9]+,admin
BRIDGE_ALLOWED_NICKS=kageho

# Rate limiting (per nick)
BRIDGE_RATE_LIMIT=10
BRIDGE_RATE_WINDOW=60

# Max outbound message length
BRIDGE_MAX_MSG_LEN=420

# Strip URLs from inbound messages (0=no, 1=yes)
BRIDGE_STRIP_URLS=0

# Optional JSONL event log
# BRIDGE_LOG_FILE=/var/log/bridge/events.jsonl

# Log level (DEBUG, INFO, WARNING, ERROR)
BRIDGE_LOG_LEVEL=INFO
