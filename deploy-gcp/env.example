# T3Claw staging environment — GCP VM deployment.
# Copy to /opt/t3claw/.env and fill in all CHANGE_ME values.
# chmod 600 /opt/t3claw/.env after editing.

# ── Database ───────────────────────────────────────────────────────────────────
# Postgres runs as a sidecar container on the same Docker bridge network.
# "postgres" resolves to the postgres container via docker compose DNS.
DATABASE_URL=postgres://t3claw:CHANGE_ME@postgres:5432/t3claw
POSTGRES_PASSWORD=CHANGE_ME

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Pick one backend and uncomment the relevant block.

# Anthropic (recommended for staging):
LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# NEAR AI (alternative):
# LLM_BACKEND=nearai
# NEARAI_API_KEY=CHANGE_ME
# NEARAI_MODEL=Qwen/Qwen3.5-122B-A10B
# NEARAI_BASE_URL=https://cloud-api.near.ai

# ── Web Gateway ───────────────────────────────────────────────────────────────
GATEWAY_ENABLED=true
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3000
# Generate a strong random token: openssl rand -hex 32
GATEWAY_AUTH_TOKEN=CHANGE_ME

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a 32-byte hex key: openssl rand -hex 32
SECRETS_MASTER_KEY=CHANGE_ME

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_NAME=t3claw
CLI_ENABLED=false
ONBOARD_COMPLETED=true
T3CLAW_IN_DOCKER=true

# ── CORS allowlist ────────────────────────────────────────────────────────────
# Comma-separated, fully-qualified origins (scheme + host [+ port]) allowed to
# call the gateway from a browser. The container always auto-allows:
#   - the bind address (`http://${GATEWAY_HOST}:${GATEWAY_PORT}`)
#   - `http://localhost:${GATEWAY_PORT}`
# Every non-local origin (including the Terminal-3 Trinity FE staging and prod
# hosts) MUST be added here explicitly. The gateway runs with
# `allow_credentials(true)` and accepts `Authorization` on CORS requests, so
# this list is a credentialed trust boundary — keep it minimal and opt-in.
#
# Entries are exact-match — no wildcards, no paths. Invalid entries are logged
# and skipped at boot; duplicates of the auto-allowed bind / localhost entries
# are de-duped.
#
# Recommended values for a Terminal-3 staging deployment (uncomment and edit
# as needed for your environment):
# T3CLAW_ALLOWED_ORIGINS=https://staging.network.terminal3.io,https://network.terminal3.io,http://localhost:3200

# ── Docker image version ──────────────────────────────────────────────────────
# Pin to a specific digest or tag for deterministic deployments.
# Leave as "latest" for staging if you always want the newest push.
# T3CLAW_VERSION=latest

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Disabled by default on staging; enable if routines need container workers.
SANDBOX_ENABLED=false
SANDBOX_POLICY=readonly

# ── Optional features ─────────────────────────────────────────────────────────
HEARTBEAT_ENABLED=false
EMBEDDING_ENABLED=false
