# Example isolated xmpp-bridge environment.
# The test harness generates a concrete copy under:
#   ${LUNARWING_TEST_ROOT:-/tmp/lunarwing-xmpp-test}/env/xmpp-bridge.env

IRONCLAW_BASE_DIR=/tmp/lunarwing-xmpp-test/state
XMPP_BRIDGE_BIND=127.0.0.1:8787
XMPP_BRIDGE_TOKEN=replace-with-random-token
XMPP_BRIDGE_MAX_MESSAGES=256
RUST_LOG=xmpp_bridge=info,info

# Leave these empty for local bridge API smoke tests.
# Fill them only for live XMPP integration tests.
XMPP_JID=
XMPP_PASSWORD=
XMPP_DM_POLICY=allowlist
XMPP_ALLOW_FROM_JSON=[]
XMPP_ALLOW_ROOMS_JSON=[]
XMPP_ENCRYPTED_ROOMS_JSON=[]
XMPP_DEVICE_ID=0
XMPP_OMEMO_STORE_DIR=/tmp/lunarwing-xmpp-test/state/xmpp
XMPP_ALLOW_PLAINTEXT_FALLBACK=true
XMPP_RESOURCE=lunarwing-test
XMPP_BRIDGE_WAIT_SECONDS=15
