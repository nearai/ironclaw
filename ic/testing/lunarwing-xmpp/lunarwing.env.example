# Example isolated LunarWing environment.
# The test harness generates a concrete copy under:
#   ${LUNARWING_TEST_ROOT:-/tmp/lunarwing-xmpp-test}/env/lunarwing.env

IRONCLAW_BASE_DIR=/tmp/lunarwing-xmpp-test/state
DATABASE_BACKEND=libsql
LIBSQL_PATH=/tmp/lunarwing-xmpp-test/state/ironclaw.db
RUST_LOG=ironclaw=info,lunarwing=info

# Add live agent credentials only when running full integration tests.
# Prefer running onboarding against the isolated IRONCLAW_BASE_DIR instead of
# sharing your normal ~/.ironclaw state.
