{
  "version": "0.1.0",
  "wit_version": "0.3.0",
  "type": "channel",
  "name": "feishu",
  "description": "Feishu (Lark) Bot channel for receiving and responding to Feishu messages",
  "auth": {
    "secret_name": "feishu_app_id",
    "display_name": "Feishu",
    "instructions": "Create a Feishu app at https://open.feishu.cn/app. Enable the Bot capability and Event Subscription. You need the App ID, App Secret, and Verification Token.",
    "setup_url": "https://open.feishu.cn/app",
    "token_hint": "App ID looks like cli_xxxx, App Secret is a 32-char hex string",
    "env_var": "FEISHU_APP_ID"
  },
  "setup": {
    "required_secrets": [
      {
        "name": "feishu_app_id",
        "prompt": "Enter your Feishu App ID (from open.feishu.cn/app)",
        "optional": false
      },
      {
        "name": "feishu_app_secret",
        "prompt": "Enter your Feishu App Secret",
        "optional": false
      },
      {
        "name": "feishu_verification_token",
        "prompt": "Enter your Feishu Event Subscription Verification Token",
        "optional": false
      },
      {
        "name": "feishu_encrypt_key",
        "prompt": "Enter your Feishu Event Subscription Encrypt Key (optional, for event encryption)",
        "optional": true
      }
    ],
    "setup_url": "https://open.feishu.cn/app"
  },
  "capabilities": {
    "http": {
      "allowlist": [
        { "host": "open.feishu.cn", "path_prefix": "/open-apis/" }
      ],
      "credentials": {
        "feishu_tenant": {
          "secret_name": "feishu_tenant_token",
          "location": { "type": "header", "name": "Authorization", "prefix": "Bearer " },
          "host_patterns": ["open.feishu.cn"],
          "oauth2": {
            "token_url": "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal",
            "grant_type": "custom",
            "body_template": "{\"app_id\":\"{feishu_app_id}\",\"app_secret\":\"{feishu_app_secret}\"}",
            "token_field": "tenant_access_token",
            "expires_field": "expire"
          }
        }
      },
      "max_response_bytes": 52428800,
      "rate_limit": {
        "requests_per_minute": 30,
        "requests_per_hour": 1000
      }
    },
    "secrets": {
      "allowed_names": ["feishu_*"]
    },
    "channel": {
      "allowed_paths": ["/webhook/feishu"],
      "allow_polling": false,
      "workspace_prefix": "channels/feishu/",
      "emit_rate_limit": {
        "messages_per_minute": 100,
        "messages_per_hour": 5000
      },
      "webhook": {
        "secret_header": "X-Feishu-Verification-Token",
        "secret_name": "feishu_verification_token"
      }
    }
  },
  "config": {
    "bot_name": null,
    "owner_open_id": null,
    "respond_to_all_group_messages": false,
    "dm_policy": "pairing",
    "allow_from": []
  }
}
