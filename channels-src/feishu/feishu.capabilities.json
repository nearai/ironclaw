{
  "version": "0.1.0",
  "wit_version": "0.3.0",
  "type": "channel",
  "name": "feishu",
  "description": "Feishu/Lark Bot channel for receiving and responding to Feishu messages via Event Subscription websocket or webhooks",
  "auth": {
    "secret_name": "feishu_app_id",
    "display_name": "Feishu / Lark",
    "instructions": "Create a bot at https://open.feishu.cn/app (Feishu) or https://open.larksuite.com/app (Lark). You need the App ID and App Secret. In Event Subscription, choose long connection websocket mode and subscribe to im.message.receive_v1. Grant the app permissions required by the message types and features you enable, then publish or update the app for the permission changes to take effect.",
    "setup_url": "https://open.feishu.cn/app",
    "token_hint": "App ID looks like cli_XXXX, App Secret is a long alphanumeric string",
    "env_var": "FEISHU_APP_ID"
  },
  "setup": {
    "required_secrets": [
      {
        "name": "feishu_app_id",
        "prompt": "Enter your Feishu/Lark App ID (from https://open.feishu.cn/app or https://open.larksuite.com/app).",
        "optional": false
      },
      {
        "name": "feishu_app_secret",
        "prompt": "Enter your Feishu/Lark App Secret (from your app settings at open.feishu.cn)",
        "optional": false
      },
      {
        "name": "feishu_verification_token",
        "prompt": "Enter your Feishu/Lark Verification Token (optional for websocket mode; required only if you choose webhook delivery)",
        "optional": true,
        "visible_when": { "name": "connection_mode", "value": "webhook" },
        "required_when_visible": true
      }
    ],
    "secret_config_mappings": [
      { "config_key": "app_id", "secret_name": "feishu_app_id" },
      { "config_key": "app_secret", "secret_name": "feishu_app_secret" },
      { "config_key": "verification_token", "secret_name": "feishu_verification_token" }
    ],
    "required_fields": [
      {
        "name": "connection_mode",
        "prompt": "Message receiving mode",
        "optional": true,
        "input_type": "select",
        "default": "websocket",
        "options": [
          { "value": "websocket", "label": "Long connection (recommended)" },
          { "value": "webhook", "label": "Webhook fallback" }
        ]
      }
    ],
    "setup_url": "https://open.feishu.cn/app"
  },
  "capabilities": {
    "http": {
      "allowlist": [
        { "host": "open.feishu.cn", "path_prefix": "/open-apis/" },
        { "host": "open.larksuite.com", "path_prefix": "/open-apis/" },
        { "host": "open.feishu.cn", "path_prefix": "/callback/ws/endpoint", "methods": ["POST"] },
        { "host": "open.larksuite.com", "path_prefix": "/callback/ws/endpoint", "methods": ["POST"] }
      ],
      "credentials": {
        "feishu_bearer": {
          "secret_name": "feishu_tenant_access_token",
          "location": { "type": "bearer" },
          "host_patterns": ["open.feishu.cn", "open.larksuite.com"]
        }
      },
      "rate_limit": {
        "requests_per_minute": 60,
        "requests_per_hour": 2000
      }
    },
    "websocket": {
      "url": "https://open.feishu.cn",
      "allowed_base_urls": [
        "https://open.feishu.cn",
        "https://open.larksuite.com"
      ],
      "allowed_connect_hosts": [
        "*.feishu.cn",
        "*.larksuite.com"
      ],
      "connect_on_start": true,
      "protocol": "feishu_event",
      "app_id_secret_name": "feishu_app_id",
      "app_secret_name": "feishu_app_secret",
      "base_url_workspace_path": "api_base"
    },
    "secrets": {
      "allowed_names": ["feishu_*"]
    },
    "channel": {
      "allowed_paths": ["/webhook/feishu"],
      "allow_polling": true,
      "workspace_prefix": "channels/feishu/",
      "emit_rate_limit": {
        "messages_per_minute": 100,
        "messages_per_hour": 5000
      },
      "webhook": {
        "secret_header": "X-Feishu-Verification-Token",
        "secret_name": "feishu_verification_token",
        "managed_by_host": false
      }
    }
  },
  "config": {
    "app_id": null,
    "app_secret": null,
    "verification_token": null,
    "connection_mode": "websocket",
    "api_base": "https://open.feishu.cn",
    "owner_id": null,
    "dm_policy": "pairing",
    "allow_from": []
  }
}
