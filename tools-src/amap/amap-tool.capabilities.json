{
  "version": "0.1.0",
  "wit_version": "0.3.0",
  "description": "高德地图 API — 地理编码、逆地理编码、POI 搜索、路径规划",
  "capabilities": {
    "http": {
      "allowlist": [
        {
          "host": "restapi.amap.com",
          "path_prefix": "/",
          "methods": [
            "GET"
          ]
        }
      ],
      "credentials": {
        "amap_key": {
          "secret_name": "amap_key",
          "location": {
            "type": "query",
            "name": "key"
          },
          "host_patterns": [
            "restapi.amap.com"
          ]
        }
      },
      "rate_limit": {
        "requests_per_minute": 100,
        "requests_per_hour": 3000
      }
    },
    "secrets": {
      "allowed_names": [
        "amap_key"
      ]
    }
  },
  "auth": {
    "secret_name": "amap_key",
    "display_name": "高德地图 (Amap)",
    "instructions": "在高德开放平台申请 Key: lbs.amap.com",
    "setup_url": "https://lbs.amap.com/",
    "env_var": "AMAP_KEY"
  },
  "setup": {
    "required_secrets": [
      {
        "name": "amap_key",
        "prompt": "高德地图 Key (从 lbs.amap.com 获取)"
      }
    ]
  }
}
