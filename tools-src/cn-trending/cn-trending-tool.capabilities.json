{
  "version": "0.1.0",
  "wit_version": "0.3.0",
  "description": "国内热搜聚合 — 知乎、微博、百度、抖音、B站多平台热门话题",
  "capabilities": {
    "http": {
      "allowlist": [
        {
          "host": "api.vvhan.com",
          "path_prefix": "/api/hotlist",
          "methods": [
            "GET"
          ]
        },
        {
          "host": "tenapi.cn",
          "path_prefix": "/v2/",
          "methods": [
            "GET"
          ]
        }
      ],
      "rate_limit": {
        "requests_per_minute": 30,
        "requests_per_hour": 300
      }
    },
    "secrets": {
      "allowed_names": []
    }
  },
  "auth": null,
  "setup": {
    "required_secrets": []
  }
}
