{
  "version": "0.1.0",
  "wit_version": "0.3.0",
  "description": "Query Alipay trade and refund status (支付宝). Simplified tool that works with a pre-generated gateway token from your backend. Authentication is handled via the 'alipay_gateway_token' secret injected by the host.",
  "capabilities": {
    "http": {
      "allowlist": [
        {
          "host": "openapi.alipay.com",
          "path_prefix": "/gateway.do",
          "methods": ["POST"]
        }
      ],
      "credentials": {
        "alipay_gateway_token": {
          "secret_name": "alipay_gateway_token",
          "location": {
            "type": "query",
            "name": "app_auth_token"
          },
          "host_patterns": ["openapi.alipay.com"]
        }
      },
      "rate_limit": {
        "requests_per_minute": 30,
        "requests_per_hour": 500
      }
    },
    "secrets": {
      "allowed_names": ["alipay_gateway_token"]
    }
  },
  "auth": {
    "secret_name": "alipay_gateway_token",
    "display_name": "支付宝 (Alipay)",
    "instructions": "需要通过后端服务生成网关 Token，详见支付宝开放平台文档",
    "setup_url": "https://open.alipay.com/",
    "env_var": "ALIPAY_GATEWAY_TOKEN"
  },
  "setup": {
    "required_secrets": [
      {
        "name": "alipay_gateway_token",
        "prompt": "Alipay gateway token (generated by your backend service)"
      }
    ]
  }
}
