{
  "name": "google_drive_readonly",
  "display_name": "Google Drive (Read-only)",
  "kind": "tool",
  "version": "0.2.1",
  "wit_version": "0.3.0",
  "description": "Search, access, and download Google Drive files and folders with read-only OAuth access",
  "keywords": [
    "storage",
    "google",
    "files",
    "drive",
    "readonly"
  ],
  "source": {
    "dir": "tools-src/google-drive",
