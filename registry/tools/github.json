{
  "name": "github",
  "display_name": "GitHub",
  "kind": "tool",
  "version": "0.1.0",
  "wit_version": "0.3.0",
  "description": "GitHub integration for repositories, issues, pull requests, search, branches, file writes, releases, and workflows",
  "keywords": [
    "git",
    "code",
    "issues",
    "pull-requests",
    "repositories",
    "search",
    "releases"
  ],
  "source": {
    "dir": "tools-src/github",
    "capabilities": "github-tool.capabilities.json",
    "crate_name": "github-tool"
  },
  "artifacts": {
    "wasm32-wasip2": {
      "url": "https://github.com/terminal-3/bastionclaw/releases/download/bastionclaw-v0.1.0/tool-github-0.1.0-wasm32-wasip2.tar.gz",
      "sha256": "27811925d5412f97fa53fe8325eb1073715816d50683e42de7c05274f1dbc7d6"
    }
  },
  "auth_summary": {
    "method": "manual",
    "provider": "GitHub",
    "secrets": [
      "github_token"
    ],
    "shared_auth": null,
    "setup_url": "https://github.com/settings/tokens"
  },
  "tags": [
    "default",
    "development"
  ]
}
