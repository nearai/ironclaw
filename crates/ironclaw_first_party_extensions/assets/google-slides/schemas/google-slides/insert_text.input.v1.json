{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Google Slides insert_text",
  "description": "Insert text into a shape.",
  "type": "object",
  "required": [
    "presentation_id",
    "object_id",
    "text"
  ],
  "properties": {
    "presentation_id": {
      "type": "string",
      "description": "The presentation ID."
    },
    "object_id": {
      "type": "string",
      "description": "Shape/text box object ID."
    },
    "text": {
      "type": "string",
      "description": "Text to insert."
    },
    "insertion_index": {
      "type": "integer",
      "description": "Character index. Defaults to 0."
    }
  },
  "additionalProperties": false
}
