{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub list_pull_requests input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository owner or organization."
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository name."
    },
    "state": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "all"
      ],
      "default": "open"
    },
    "page": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "1-based results page."
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 30,
      "description": "Maximum number of pull requests to return."
    },
    "head": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "description": "Optional head user or branch filter, for example user:branch."
    },
    "base": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "description": "Optional base branch filter."
    },
    "sort": {
      "type": "string",
      "enum": [
        "created",
        "updated",
        "popularity",
        "long-running"
      ],
      "description": "Optional pull request sort field."
    },
    "direction": {
      "type": "string",
      "enum": [
        "asc",
        "desc"
      ],
      "description": "Sort direction when sort is supplied."
    }
  },
  "required": [
    "owner",
    "repo"
  ]
}
