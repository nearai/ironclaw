{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub remove_issue_label input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": { "pattern": "\\.\\." }
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": { "pattern": "\\.\\." }
    },
    "issue_number": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Label name to remove."
    }
  },
  "required": ["owner", "repo", "issue_number", "name"]
}
