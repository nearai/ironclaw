{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub create_release input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository owner or organization."
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository name."
    },
    "tag_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Release tag name."
    },
    "target_commitish": {
      "type": "string",
      "maxLength": 255,
      "description": "Target commitish."
    },
    "name": {
      "type": "string",
      "maxLength": 65536,
      "description": "Release display name."
    },
    "body": {
      "type": "string",
      "maxLength": 65536,
      "description": "Release notes."
    },
    "draft": {
      "type": "boolean",
      "default": false
    },
    "prerelease": {
      "type": "boolean",
      "default": false
    },
    "generate_release_notes": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "owner",
    "repo",
    "tag_name"
  ]
}
