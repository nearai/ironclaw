{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub trigger_workflow input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository owner or organization."
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository name."
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Workflow file name or numeric id."
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Branch, tag, or SHA to run on."
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "owner",
    "repo",
    "workflow_id",
    "ref"
  ]
}
