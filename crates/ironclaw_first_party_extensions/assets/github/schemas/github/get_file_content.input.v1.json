{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub get_file_content input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository owner or organization."
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository name."
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "description": "Repository file path."
    },
    "ref": {
      "type": "string",
      "maxLength": 255,
      "description": "Branch, tag, or commit SHA."
    }
  },
  "required": [
    "owner",
    "repo",
    "path"
  ]
}
