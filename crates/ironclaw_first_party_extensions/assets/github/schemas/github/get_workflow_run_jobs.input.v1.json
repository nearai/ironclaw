{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub get_workflow_run_jobs input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": { "pattern": "\\.\\." }
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": { "pattern": "\\.\\." }
    },
    "run_id": {
      "type": "integer",
      "minimum": 1
    },
    "filter": {
      "type": "string",
      "enum": ["latest", "all"]
    },
    "page": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 30
    }
  },
  "required": ["owner", "repo", "run_id"]
}
