{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub list_repos input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "username": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "GitHub username."
    },
    "page": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 1
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 30
    }
  },
  "required": [
    "username"
  ]
}
