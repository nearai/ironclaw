{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub list_pull_request_comments input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository owner or organization."
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": {
        "pattern": "\\.\\."
      },
      "description": "Repository name."
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Pull request number."
    },
    "sort": {
      "type": "string",
      "enum": [
        "created",
        "updated"
      ],
      "description": "Optional review-comment sort field."
    },
    "direction": {
      "type": "string",
      "enum": [
        "asc",
        "desc"
      ],
      "description": "Sort direction when sort is supplied."
    },
    "since": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "format": "date-time",
      "description": "Only show results updated after this ISO 8601 timestamp."
    },
    "page": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 30
    }
  },
  "required": [
    "owner",
    "repo",
    "pr_number"
  ]
}
