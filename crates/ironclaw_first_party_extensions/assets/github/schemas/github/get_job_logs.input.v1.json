{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub get_job_logs input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": { "pattern": "\\.\\." }
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^\\s/?#]+$",
      "not": { "pattern": "\\.\\." }
    },
    "job_id": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": ["owner", "repo", "job_id"]
}
