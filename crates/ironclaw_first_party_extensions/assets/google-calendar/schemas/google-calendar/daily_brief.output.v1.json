{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Google Calendar daily_brief output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "date",
    "window",
    "timeZone",
    "timeMin",
    "timeMax",
    "agenda",
    "emailAttention",
    "partialFailures"
  ],
  "properties": {
    "kind": { "const": "ironclaw#googleCalendarDailyBrief" },
    "date": { "type": ["string", "null"] },
    "window": { "type": ["string", "null"] },
    "timeZone": { "type": ["string", "null"] },
    "timeMin": { "type": ["string", "null"] },
    "timeMax": { "type": ["string", "null"] },
    "agenda": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventCount", "events", "calendarIds", "calendars"],
      "properties": {
        "eventCount": { "type": ["integer", "null"], "minimum": 0 },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/event" }
        },
        "calendarIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "calendars": {
          "type": "array",
          "items": { "$ref": "#/definitions/calendar" }
        }
      }
    },
    "emailAttention": { "$ref": "#/definitions/gmailSummaries" },
    "partialFailures": {
      "type": "array",
      "items": { "$ref": "#/definitions/partialFailure" }
    }
  },
  "definitions": {
    "calendar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "primary"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "primary": { "type": "boolean" }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "calendarId",
        "summary",
        "start",
        "end",
        "location",
        "htmlLink",
        "hangoutLink",
        "descriptionPreview",
        "attendeeCount",
        "attendees"
      ],
      "properties": {
        "id": { "type": "string" },
        "calendarId": { "type": "string" },
        "summary": { "type": "string" },
        "start": { "type": ["string", "null"] },
        "end": { "type": ["string", "null"] },
        "location": { "type": "string" },
        "htmlLink": { "type": "string" },
        "hangoutLink": { "type": "string" },
        "descriptionPreview": { "type": "string" },
        "attendeeCount": { "type": "integer", "minimum": 0 },
        "attendees": {
          "type": "array",
          "items": { "$ref": "#/definitions/attendee" }
        }
      }
    },
    "attendee": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email", "displayName", "responseStatus", "organizer"],
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "responseStatus": { "type": "string" },
        "organizer": { "type": "boolean" }
      }
    },
    "gmailSummaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "query",
        "labelIds",
        "resultSizeEstimate",
        "nextPageToken",
        "messages",
        "messageCount",
        "unreadCount",
        "partialFailures"
      ],
      "properties": {
        "kind": { "const": "ironclaw#gmailMessageSummaries" },
        "query": { "type": ["string", "null"] },
        "labelIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resultSizeEstimate": { "type": ["integer", "null"], "minimum": 0 },
        "nextPageToken": { "type": ["string", "null"] },
        "messages": {
          "type": "array",
          "items": { "$ref": "#/definitions/messageSummary" }
        },
        "messageCount": { "type": "integer", "minimum": 0 },
        "unreadCount": { "type": "integer", "minimum": 0 },
        "partialFailures": {
          "type": "array",
          "items": { "$ref": "#/definitions/gmailPartialFailure" }
        }
      }
    },
    "messageSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "threadId",
        "from",
        "to",
        "subject",
        "date",
        "snippet",
        "bodyPreview",
        "labelIds",
        "isUnread"
      ],
      "properties": {
        "id": { "type": "string" },
        "threadId": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "date": { "type": "string" },
        "snippet": { "type": "string" },
        "bodyPreview": { "type": "string" },
        "labelIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isUnread": { "type": "boolean" }
      }
    },
    "gmailPartialFailure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scope": { "type": "string" },
        "messageId": { "type": "string" },
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "reason": { "type": ["string", "null"] }
      },
      "required": ["status", "reason"],
      "anyOf": [{ "required": ["scope"] }, { "required": ["messageId"] }]
    },
    "partialFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "status", "reason", "source"],
      "properties": {
        "scope": { "type": "string" },
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "reason": { "type": ["string", "null"] },
        "source": { "enum": ["calendar", "gmail"] }
      }
    }
  }
}
