{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Google Calendar agenda output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "date",
    "window",
    "timeZone",
    "timeMin",
    "timeMax",
    "calendarIds",
    "calendars",
    "events",
    "eventCount",
    "partialFailures"
  ],
  "properties": {
    "kind": { "const": "ironclaw#calendarAgenda" },
    "date": { "type": ["string", "null"] },
    "window": { "type": ["string", "null"] },
    "timeZone": { "type": ["string", "null"] },
    "timeMin": { "type": ["string", "null"] },
    "timeMax": { "type": ["string", "null"] },
    "calendarIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "calendars": {
      "type": "array",
      "items": { "$ref": "#/definitions/calendar" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/definitions/event" }
    },
    "eventCount": { "type": "integer", "minimum": 0 },
    "partialFailures": {
      "type": "array",
      "items": { "$ref": "#/definitions/partialFailure" }
    }
  },
  "definitions": {
    "calendar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "primary"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "primary": { "type": "boolean" }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "calendarId",
        "summary",
        "start",
        "end",
        "location",
        "htmlLink",
        "hangoutLink",
        "descriptionPreview",
        "attendeeCount",
        "attendees"
      ],
      "properties": {
        "id": { "type": "string" },
        "calendarId": { "type": "string" },
        "summary": { "type": "string" },
        "start": { "type": ["string", "null"] },
        "end": { "type": ["string", "null"] },
        "location": { "type": "string" },
        "htmlLink": { "type": "string" },
        "hangoutLink": { "type": "string" },
        "descriptionPreview": { "type": "string" },
        "attendeeCount": { "type": "integer", "minimum": 0 },
        "attendees": {
          "type": "array",
          "items": { "$ref": "#/definitions/attendee" }
        }
      }
    },
    "attendee": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email", "displayName", "responseStatus", "organizer"],
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "responseStatus": { "type": "string" },
        "organizer": { "type": "boolean" }
      }
    },
    "partialFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "status", "reason"],
      "properties": {
        "scope": { "type": "string" },
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "reason": { "type": ["string", "null"] },
        "source": { "type": "string" }
      }
    }
  }
}
