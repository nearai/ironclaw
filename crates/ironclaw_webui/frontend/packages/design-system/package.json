{
  "name": "@ironclaw/design-system",
  "version": "0.1.0",
  "description": "IronClaw design system — Radix-based, shadcn-patterned React components, --v2-* design tokens, and motion vocabulary. Source-first: consumers compile the TSX through their own bundler (Tailwind v4 + Vite recommended); `pnpm build` also emits a compiled ESM bundle in dist/ for non-Tailwind hosts.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens.css",
    "./themes/soft.css": "./src/themes/soft.css",
    "./tokens": "./src/tokens.ts",
    "./motion": "./src/motion.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-themes": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@tailwindcss/vite": "4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.5.3",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "motion": "12.42.2",
    "tailwind-merge": "^3.6.0"
  }
}
