{
  "name": "ironclaw-webui-v2-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "Build tooling for the WebUI v2 SPA. Vite builds the TypeScript source and public assets into ignored dist/ output that Rust embeds when webui-v2-beta is enabled.",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm lint:conventions && pnpm typecheck",
    "lint:conventions": "node --experimental-strip-types scripts/check-source-conventions.ts",
    "test": "vitest run",
    "vendor": "bash vendor.sh",
    "all": "bash build.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "5.87.4",
    "dompurify": "3.2.3",
    "highlight.js": "11.11.1",
    "marked": "17.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.62.0",
    "react-hot-toast": "2.6.0",
    "react-router": "7.15.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  }
}
