{
  "compilerOptions": {
    "checkJs": false,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["node", "react", "react-dom", "vite/client"]
  },
  "include": ["scripts", "src", "vite.config.ts"]
}
