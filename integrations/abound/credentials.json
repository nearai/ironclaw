{
  "description": "Abound API credential mappings — loaded via INTEGRATION_CREDENTIALS env var",
  "mappings": [
    {
      "secret_name": "abound_read_token",
      "location": { "type": "bearer" },
      "host_patterns": [
        "devneobank.timesclub.co",
        "api.joinabound.co",
        "dev.timesclub.co",
        "api.timesclub.co"
      ],
      "path_patterns": [
        "/times/bank/remittance/agent/account/info",
        "/times/bank/remittance/agent/exchange-rate",
        "/bank/remittance/agent/account/info",
        "/bank/remittance/agent/exchange-rate",
        "/times/users/agent/create-notification",
        "/users/agent/create-notification"
      ]
    },
    {
      "secret_name": "abound_write_token",
      "location": { "type": "bearer" },
      "host_patterns": [
        "devneobank.timesclub.co",
        "api.joinabound.co"
      ],
      "path_patterns": [
        "/times/bank/remittance/agent/send-wire",
        "/bank/remittance/agent/send-wire"
      ]
    },
    {
      "secret_name": "abound_api_key",
      "location": { "type": "header", "name": "X-API-KEY" },
      "host_patterns": [
        "devneobank.timesclub.co",
        "api.joinabound.co",
        "dev.timesclub.co",
        "api.timesclub.co"
      ]
    }
  ]
}
