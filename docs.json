{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "IronClaw",
  "colors": {
    "primary": "#1191f0",
    "light": "#1191f0",
    "dark": "#1191f0"
  },
  "favicon": "/images/logo/favicon.ico",
  "logo": {
    "light": "/images/logo/logo.svg",
    "dark": "/images/logo/logo-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://t.me/ironclawAI"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Deploy Now",
      "href": "https://agent.near.ai/"
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": " ",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "index",
                  "quickstart",
                  "onboard"
                ]
              },
              {
                "group": "Channels",
                "pages": [
                  "tunnel",
                  {
                    "group": "Available Channels",
                    "icon": "message",
                    "pages": [
                      "channels/local",
                      "channels/signal",
                      "channels/telegram",
                      "channels/webhook"
                    ]
                  }
                ]
              },
              {
                "group": "Extensions (Tools)",
                "pages": [
                  "extensions/web-search",
                  "extensions/github"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "zh",
        "navbar": {
          "links": [
            {
              "label": "支持",
              "href": "https://t.me/ironclawAI"
            }
          ],
          "primary": {
            "type": "button",
            "label": "立即部署",
            "href": "https://agent.near.ai/"
          }
        },
        "tabs": [
          {
            "tab": " ",
            "groups": [
              {
                "group": "快速开始",
                "pages": [
                  "zh/index",
                  "zh/quickstart",
                  "zh/onboard"
                ]
              },
              {
                "group": "渠道",
                "pages": [
                  "zh/tunnel",
                  {
                    "group": "可用渠道",
                    "icon": "message",
                    "pages": [
                      "zh/channels/local",
                      "zh/channels/signal",
                      "zh/channels/telegram",
                      "zh/channels/webhook"
                    ]
                  }
                ]
              },
              {
                "group": "扩展（工具）",
                "pages": [
                  "zh/extensions/web-search",
                  "zh/extensions/github"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Agent Dashboard",
          "href": "https://agent.near.ai/",
          "icon": "sliders"
        },
        {
          "anchor": "NEAR AI Cloud",
          "href": "https://cloud.near.ai",
          "icon": "cloud"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/near_ai",
      "github": "https://github.com/nearai",
      "linkedin": "https://linkedin.com/company/near-ai"
    }
  }
