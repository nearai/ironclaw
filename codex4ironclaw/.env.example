# IronClaw environment variables

# Provider configuration
# Set this to another repo-local TOML file, for example ./config/chatgpt-pro.toml.
CODEX_CONFIG_FILE=./config/config.toml
OPENAI_API_KEY=
OPENAI_BASE_URL=
CODEX_MODEL=

# Worker runtime
CODEX_MODE=websocket
WS_ROLE=server
IRONCLAW_WORKER_ID=worker-codex-01
CODEX_BYPASS_SANDBOX=true
HEALTH_PORT=8443
WS_BIND_HOST=0.0.0.0
WS_PORT=9090
WS_PATH=/ws/agent
WORKSPACE_ROOT=/workspace
LOG_LEVEL=info
HOST_GID=1000
FILE_UMASK=0002

# Agent authentication (generate with: openssl rand -hex 32)
AGENT_AUTH_TOKEN=your-secure-auth-token-here

# Optional demo agent prompt
TASK_PROMPT=Write a hello world Python script
TASK_TIMEOUT_MS=300000

# Optional ACP stdio bridge settings for OpenClaw/acpx-style adapters
ACP_WORKER_WS_URL=ws://127.0.0.1:9090/ws/agent
ACP_PROJECT_DIR=/workspace
ACP_USE_SESSION_CWD=false
